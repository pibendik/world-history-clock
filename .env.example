# YearClock configuration
# Copy to .env and fill in your values

# Your public domain name (required for production HTTPS)
YEARCLOCK_DOMAIN=yourdomain.com

YEARCLOCK_PORT=8421
YEARCLOCK_DB_PATH=/data/yearclock.db
YEARCLOCK_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
YEARCLOCK_CACHE_TTL_DAYS=7
# Restrict to your domain in production; ["*"] is fine for local dev
YEARCLOCK_CORS_ORIGINS=["https://yourdomain.com"]
# YEARCLOCK_CURRENT_YEAR is auto-set to today's year — override only if needed

# ---------------------------------------------------------------------------
# LLM content scoring (optional — app works fully without this)
# ---------------------------------------------------------------------------
# When enabled, each set of Wikidata results is passed through gpt-4o-mini
# which filters out uninteresting entries (sport seasons, local admin events,
# abstract concepts, etc.) before the fact is cached.
#
# Cost: ~$0.001–0.003 per unique year fetched (1440 total clock years).
# The result is cached in SQLite, so each year is scored at most once per
# cache TTL (default 7 days). Running --clear-cache triggers a full rescore.
#
# To enable:
#   1. Get an OpenAI API key at https://platform.openai.com/api-keys
#   2. Set the two variables below
#   3. Redeploy (./deploy.sh root@IP --clear-cache)
#
# OPENAI_API_KEY=sk-...
# YEARCLOCK_LLM_SCORING=true

