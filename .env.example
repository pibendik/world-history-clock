# YearClock configuration
# Copy to .env and fill in your values

# Your public domain name (required for production HTTPS)
YEARCLOCK_DOMAIN=yourdomain.com

YEARCLOCK_PORT=8421
YEARCLOCK_DB_PATH=/data/yearclock.db
YEARCLOCK_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
YEARCLOCK_CACHE_TTL_DAYS=7
# Restrict to your domain in production; ["*"] is fine for local dev
YEARCLOCK_CORS_ORIGINS=["https://yourdomain.com"]
# YEARCLOCK_CURRENT_YEAR is auto-set to today's year — override only if needed
